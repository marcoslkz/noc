BASE_DIR=/opt/monitoring/data
BASE_DIR_CONF=/opt/monitoring/config

CUSTOM_HOSTNAME=nome-do-servidor
TZ=America/Sao_Paulo
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push

GRAFANA_IMAGE=grafana/grafana:<version>
LOKI_IMAGE=grafana/loki:<version>
PROMETHEUS_IMAGE=prom/prometheus:<version>
ALLOY_IMAGE=grafana/alloy:<version>
MIMIR_IMAGE=grafana/mimir:<version>
SYSLOG_NG_IMAGE=balabit/syslog-ng:latest

GRAFANA_PORT=3000
ALLOY_SYSLOG_PORT=1514
SYSLOG_NG_PORT=1515

PROMETHEUS_RETENTION=15d
MIMIR_RETENTION=1y

GF_SMTP_ENABLED=true
GF_SMTP_HOST=mail.cecierj.edu.br:25
GF_SMTP_FROM_ADDRESS=noreply_grafana@exemplo.com
GF_SMTP_FROM_NAME=Grafana
GF_SMTP_SKIP_VERIFY=true

GF_LOG_LEVEL=warn
GF_LOKI_INTERNAL_URL=http://loki:3100

SITE_PATH=monitoring
ROOT_DOMAIN=exemplo.com
